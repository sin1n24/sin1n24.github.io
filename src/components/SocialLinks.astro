---
// SNSリンクの丸型アイコンボタン群。Footer/Heroで共用する。
// X/GitHub/YouTube/EmailはインラインSVG、MakerWorld/Blogは旧Hydejack版から
// 引き継いだPNGマスク方式(currentColor追従、icon-makerworld.png/icon-blog.png)。
import { SOCIAL_LINKS } from '../data/site';

interface Props {
  class?: string;
}

const { class: className } = Astro.props;

const svgIcons: Record<string, string> = {
  x: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.9 2H22l-7.6 8.7L23.3 22h-7.2l-5.6-6.9L4 22H1l8.1-9.3L0.9 2h7.4l5.1 6.3L18.9 2zm-1.3 18h2L6.5 4H4.4l13.2 16z"/></svg>`,
  github: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.93.57.1.78-.25.78-.55 0-.27-.01-1.16-.02-2.1-3.2.7-3.87-1.36-3.87-1.36-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.03 1.77 2.71 1.26 3.37.96.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11.1 11.1 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.12 3.05.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.07.78 2.16 0 1.56-.01 2.82-.01 3.2 0 .31.2.66.79.55A10.51 10.51 0 0 0 23.5 12c0-6.35-5.15-11.5-11.5-11.5z"/></svg>`,
  youtube: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.11-2.13C19.5 3.5 12 3.5 12 3.5s-7.5 0-9.39.57A3 3 0 0 0 .5 6.2 31.6 31.6 0 0 0 0 12a31.6 31.6 0 0 0 .5 5.8 3 3 0 0 0 2.11 2.13C4.5 20.5 12 20.5 12 20.5s7.5 0 9.39-.57a3 3 0 0 0 2.11-2.13A31.6 31.6 0 0 0 24 12a31.6 31.6 0 0 0-.5-5.8zM9.6 15.6V8.4l6.4 3.6-6.4 3.6z"/></svg>`,
  email: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true"><rect x="2" y="4.5" width="20" height="15" rx="2"/><path d="M3 6l9 7 9-7" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
};
---

<nav class:list={['social-links', className]} aria-label="ソーシャルリンク">
  {SOCIAL_LINKS.map((link) => (
    <a
      href={link.url}
      target={link.url.startsWith('mailto:') ? undefined : '_blank'}
      rel="noopener noreferrer"
      aria-label={link.name}
      title={link.name}
    >
      {svgIcons[link.icon] ? (
        <Fragment set:html={svgIcons[link.icon]} />
      ) : (
        <span class={`social-icon icon-${link.icon}`} />
      )}
    </a>
  ))}
</nav>
