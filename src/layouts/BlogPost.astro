---
import Base from './Base.astro';
import CategoryTags from '../components/CategoryTags.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  categories?: string[];
}

const { title, date, description, categories } = Astro.props;

// 現行サイト踏襲のフォーマット: YYYY年MM月DD日
const y = date.getFullYear();
const m = String(date.getMonth() + 1).padStart(2, '0');
const d = String(date.getDate()).padStart(2, '0');
const dateLabel = `${y}年${m}月${d}日`;
---

<Base title={title} description={description}>
  <!-- data-pagefind-body: このブロックのみを検索対象にする（nav/footer等の共通要素や
       他ページを索引ノイズにしないため、記事詳細ページに限定してPagefindへ範囲指定） -->
  <article data-pagefind-body>
    <header class="post-header container">
      <h1 class="post-title-main">{title}</h1>
      <p class="post-date-main">{dateLabel}</p>
      <CategoryTags categories={categories} class="post-categories-main" />
    </header>
    <div class="post-body container">
      <slot />
      <a class="btn post-back" href="/blog/" data-pagefind-ignore>← ブログ一覧へ戻る</a>
    </div>
  </article>
</Base>
