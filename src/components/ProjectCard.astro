---
// _data/projects.yml 用のカード。画像 + タイトル + 説明 + タグ + ボタン（詳細を見る / 販売サイト）
// カード全体をリンクにはせず、ボタンを明示することでshop_urlとの二重リンクを避ける。
interface Props {
  title: string;
  url: string;
  image?: string;
  description?: string;
  tags?: string[];
  shop_url?: string;
  try_url?: string;
  official_url?: string;
}

const { title, url, image, description, tags, shop_url, try_url, official_url } = Astro.props;

// ローカル画像(/img/...)はビルド時にWebPも生成済みなのでpictureで出し分ける。
// 外部URL(YouTubeサムネイル等)はJPEGのみなのでそのままimgで表示する。
const isLocalImage = image?.startsWith('/img/');
const webpImage = isLocalImage ? image!.replace(/\.(jpg|jpeg|png)$/i, '.webp') : undefined;

// サイト内リンク(/blog/...等)は同一タブ、外部リンクのみ新規タブで開く
const isExternal = /^https?:\/\//.test(url);
---

<div class="card reveal">
  {image ? (
    webpImage ? (
      <picture>
        <source srcset={webpImage} type="image/webp" />
        <img class="card-img" src={image} alt={title} loading="lazy" />
      </picture>
    ) : (
      <img class="card-img" src={image} alt={title} loading="lazy" />
    )
  ) : (
    <div class="card-img-placeholder"></div>
  )}
  <div class="card-body">
    <h3 class="card-title">{title}</h3>
    {description && <p class="card-desc">{description}</p>}
    {tags && tags.length > 0 && (
      <div class="card-tags">
        {tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
    <div class="card-actions">
      <a class="btn" href={url} target={isExternal ? '_blank' : undefined} rel={isExternal ? 'noopener noreferrer' : undefined}>詳細を見る</a>
      {try_url && (
        <a class="btn" href={try_url} target="_blank" rel="noopener noreferrer">使ってみる</a>
      )}
      {official_url && (
        <a class="btn" href={official_url} target="_blank" rel="noopener noreferrer">公式サイト</a>
      )}
      {shop_url && (
        <a class="btn btn-primary" href={shop_url} target="_blank" rel="noopener noreferrer">販売サイト</a>
      )}
    </div>
  </div>
</div>
